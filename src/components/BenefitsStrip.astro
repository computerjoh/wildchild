---
import { getCollection } from 'astro:content';
const benefits = await getCollection('benefits');
---

<section class="bg-ember py-12 px-6">
  <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
    {benefits.map((b) => (
      <div class="text-white">
        <div class="w-12 h-12 rounded-full bg-white/15 flex items-center justify-center mx-auto mb-3">
          <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d={b.data.icon} />
          </svg>
        </div>
        <p class="font-bold text-sm mb-0.5 text-white">{b.data.title}</p>
        <p class="text-white/90 text-xs">{b.data.sub}</p>
      </div>
    ))}
  </div>
</section>
