---
interface Props {
  title: string;
  description: string;
  href: string;
  badge?: string;
  ages?: string;
  color?: 'forest' | 'sky' | 'sunset' | 'gold';
}

const {
  title,
  description,
  href,
  badge,
  ages,
  color = 'forest',
} = Astro.props;

const colorMap = {
  forest: 'bg-forest text-white hover:bg-forest-dark',
  sky: 'bg-sky text-white hover:bg-sky/90',
  sunset: 'bg-sunset text-white hover:bg-sunset-dark',
  gold: 'bg-gold text-charcoal hover:bg-gold/90',
};

const badgeColorMap = {
  forest: 'bg-forest-light/20 text-forest-light',
  sky: 'bg-white/20 text-white',
  sunset: 'bg-white/20 text-white',
  gold: 'bg-charcoal/10 text-charcoal',
};
---

<a
  href={href}
  class="group block bg-white rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden hover:-translate-y-1"
>
  <!-- Card header -->
  <div class={`${colorMap[color]} p-6 transition-colors`}>
    <h3 class="text-2xl font-display tracking-wide mb-2">{title}</h3>
    {ages && (
      <span class={`text-xs font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full ${badgeColorMap[color]}`}>
        Ages {ages}
      </span>
    )}
  </div>

  <!-- Card body -->
  <div class="p-6">
    <p class="text-charcoal/70 leading-relaxed text-sm">{description}</p>
    {badge && (
      <span class="inline-block mt-3 text-xs font-bold uppercase tracking-wider text-sunset bg-sunset/10 px-3 py-1 rounded-full">
        {badge}
      </span>
    )}
    <div class="mt-4 flex items-center text-forest font-semibold text-sm gap-1 group-hover:gap-2 transition-all">
      Learn more
    </div>
  </div>
</a>
