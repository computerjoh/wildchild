---
interface Props {
	name: string;
	nickname: string;
	role: string;
	bio: string;
	highlights?: string[];
	image?: string;
}

const { name, nickname, role, bio, highlights = [], image } = Astro.props;

const initials = name
	.split(" ")
	.map((w) => w[0])
	.join("")
	.slice(0, 2);
---

<div class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
  <div class="relative aspect-square w-full bg-forest/10 overflow-hidden">
    {image ? (
      <img
        src={image}
        alt={`Photo of ${name}`}
        class="w-full h-full object-cover object-top"
      />
    ) : (
      <div class="w-full h-full flex flex-col items-center justify-center bg-gradient-forest">
        <span class="font-display text-6xl text-white/80 tracking-wide">{initials}</span>
        <span class="text-white/50 text-xs mt-2 uppercase tracking-widest">Photo coming soon</span>
      </div>
    )}
  </div>

  <div class="p-6">
    <div class="mb-1">
      <span class="text-xs font-bold uppercase tracking-widest text-sunset bg-sunset/10 px-2 py-0.5 rounded-full">
        "{nickname}"
      </span>
    </div>

    <h3 class="text-xl font-bold text-charcoal mt-2">{name}</h3>
    <p class="text-forest font-semibold text-sm mb-3">{role}</p>
    <p class="text-charcoal/60 text-sm leading-relaxed">{bio}</p>

    {highlights.length > 0 && (
      <ul class="mt-4 space-y-1">
        {highlights.map((h) => (
          <li class="flex items-center gap-2 text-xs text-charcoal/70">
            <span class="w-1 h-1 rounded-full bg-forest flex-shrink-0" />
            {h}
          </li>
        ))}
      </ul>
    )}
  </div>
</div>
