---
import { Image } from 'astro:assets';
import joel from '../assets/joel.webp';
---

<section id="about" class="py-20 px-6 bg-white">
  <div class="max-w-4xl mx-auto text-center">
    <p class="text-ember font-semibold uppercase tracking-widest text-sm mb-2">About Wild Child</p>
    <h2 class="font-display text-4xl sm:text-5xl text-boulder mb-4">A Very Special Place</h2>
    <p class="text-carbon/60 text-sm font-medium uppercase tracking-widest mb-6">
      Colorado Adventure Day Camp · Ages 6–15 · Westminster, CO
    </p>
    <p class="text-carbon/70 text-base leading-relaxed max-w-2xl mx-auto">
      Wild Child is a place where children can learn and grow into the person they hope to become. Every summer, campers get to be superheroes, scientists, adventurers — exactly who they want to be. We're honored to be a part of that journey.
    </p>

    <div class="mt-12 pt-10 border-t border-boulder/10">
      <Image
        src={joel}
        alt="Joel Van Egbert, Wild Child Founder"
        class="w-20 h-20 rounded-full object-cover mx-auto mb-5 border-4 border-tangerine shadow-lg"
      />
      <blockquote class="font-display text-2xl sm:text-3xl md:text-4xl text-boulder leading-tight mb-5 max-w-2xl mx-auto">
        "Kids deserve to be treated like the people they hope to become."
      </blockquote>
      <p class="text-carbon/80 text-sm font-medium">
        Joel Van Egbert, Founder & Executive Director
      </p>
      <p class="text-ember font-bold text-sm mt-1">
        Early Childhood Educator of the Year · Camp Director of the Year
      </p>
    </div>
  </div>
</section>
