---
import { getCollection } from 'astro:content';
const testimonials = await getCollection('testimonials');
---

<section id="testimonials" class="py-20 px-6 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <p class="text-ember font-semibold uppercase tracking-widest text-sm mb-2">What Parents Say</p>
      <h2 class="font-display text-4xl sm:text-5xl text-boulder mb-4">Colorado Families Love Wild Child</h2>
      <p class="text-carbon/80 max-w-lg mx-auto text-sm">
        Don't take our word for it. Hear from the parents and kids who come back year after year.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="bg-sandstone rounded-2xl p-7 border border-boulder/10 flex flex-col">
          <div class="flex gap-0.5 mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-tangerine" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-carbon/80 text-sm leading-relaxed flex-1 mb-5">"{t.data.quote}"</p>
          <div>
            <p class="font-bold text-carbon text-sm">{t.data.name}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
