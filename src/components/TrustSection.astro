---
import { getCollection } from 'astro:content';
const trustItems = await getCollection('trust');
---

<section id="why-us" class="bg-boulder py-16 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-10">
      <p class="text-tangerine font-semibold uppercase tracking-widest text-sm mb-2">Why Choose Us</p>
      <h2 class="font-display text-4xl sm:text-5xl text-white">Why Parents Trust Wild Child</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {trustItems.map((item) => (
        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-tangerine" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={item.data.icon} />
            </svg>
          </div>
          <h3 class="font-bold text-white text-sm mb-1">{item.data.title}</h3>
          <p class="text-white/60 text-xs leading-relaxed">{item.data.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
