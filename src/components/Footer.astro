---
const programs = [
  { label: 'Summer Day Camps', href: '/programs/summer-day-camps' },
  { label: 'SPLASH Camps', href: '/programs/splash' },
  { label: 'Enrichment Programs', href: '/programs/enrichment' },
  { label: 'REACH Climbing Club', href: '/programs/reach' },
  { label: 'SPARK Creative Writing', href: '/programs/spark' },
];

const company = [
  { label: 'Meet Our Staff', href: '/staff' },
  { label: 'Parent Information', href: '/parents' },
  { label: "We're Hiring!", href: '/hiring' },
];
---

<footer class="bg-forest-dark text-white">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="inline-block mb-4">
          <img
            src="/logo.webp"
            alt="Wild Child Day Camps"
            class="h-16 w-auto object-contain"
          />
        </a>
        <p class="text-white/60 text-sm leading-relaxed mb-6">
          Dream BIG. Be BRAVE. GO WILD.<br />
          Colorado's premier adventure day camp for kids ages 6–15.
        </p>
        <div class="flex gap-4">
          <a
            href="https://facebook.com/wildchildcolorado"
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/60 hover:text-gold transition-colors text-sm"
          >
            Facebook
          </a>
          <a
            href="https://instagram.com/wildchildcolorado"
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/60 hover:text-gold transition-colors text-sm"
          >
            Instagram
          </a>
        </div>
      </div>

      <!-- Programs -->
      <div>
        <h4 class="font-bold uppercase tracking-widest text-xs text-forest-light mb-4">Programs</h4>
        <ul class="space-y-2">
          {programs.map((p) => (
            <li>
              <a href={p.href} class="text-white/60 hover:text-white text-sm transition-colors">
                {p.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-bold uppercase tracking-widest text-xs text-forest-light mb-4">Info</h4>
        <ul class="space-y-2">
          {company.map((c) => (
            <li>
              <a href={c.href} class="text-white/60 hover:text-white text-sm transition-colors">
                {c.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-bold uppercase tracking-widest text-xs text-forest-light mb-4">Contact</h4>
        <address class="not-italic space-y-2 text-sm text-white/60">
          <p>
            <a href="tel:9703895611" class="hover:text-white transition-colors">
              970-389-5611
            </a>
          </p>
          <p>
            Woodrow Wilson Academy<br />
            8300 W 94th Ave<br />
            Westminster, CO 80021
          </p>
        </address>
        <a
          href="https://wildchildcamp.funjoin.app"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block mt-6 bg-sunset hover:bg-sunset-dark text-white font-bold py-2.5 px-6 rounded-full text-sm transition-colors"
        >
          Register for 2026
        </a>
      </div>
    </div>

    <div class="border-t border-white/10 mt-12 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/40">
      <p>© {new Date().getFullYear()} Wild Child Day Camps. All rights reserved.</p>
      <p>Westminster, Colorado · @wildchildcolorado</p>
    </div>
  </div>
</footer>
