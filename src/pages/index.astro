---
import { Image, getImage } from "astro:assets";
import joel from "../assets/joel.webp";
import kids from "../assets/kids.webp";
import logo from "../assets/logo.webp";
import photo1 from "../assets/1.webp";
import photo2 from "../assets/2.webp";
import photo3 from "../assets/3.webp";
import photo4 from "../assets/4.webp";
import photo5 from "../assets/5.webp";
import photo6 from "../assets/6.webp";
import photo7 from "../assets/7.webp";
import photo8 from "../assets/8.webp";
import photo9 from "../assets/9.webp";
import photo10 from "../assets/10.webp";
import photo11 from "../assets/11.webp";
import photo12 from "../assets/12.webp";
import photo13 from "../assets/13.webp";
import { benefits } from "../data/benefits";
import { programs } from "../data/programs";
import { testimonials } from "../data/testimonials";
import { trustItems } from "../data/trust";
import Layout from "../layouts/Layout.astro";

const FUNJOIN_URL = "https://wildchildcamp.funjoin.app/explore-offerings";
const MAIN_SITE_URL = "https://wildchild.camp";

const kidsPreload = await getImage({ src: kids, format: "webp", quality: 60 });

const carouselPhotos = [photo1, photo2, photo3, photo4, photo5, photo6, photo7, photo8, photo9, photo10, photo11, photo12, photo13];
---

<Layout
  title="Wild Child Day Camps: Reserve Your Summer 2026 Spot"
  description="Colorado's #1 adventure day camp for kids ages 6–15. Hiking, rafting, climbing & more. Reserve your Summer 2026 spot today. Spots fill fast."
>
  <link
    slot="head"
    rel="preload"
    as="image"
    href={kidsPreload.src}
    type="image/webp"
    fetchpriority="high"
  />

    <!-- ── 1. HEADER ── -->
    <header class="bg-boulder px-6 py-3 sticky top-0 z-50 shadow-lg border-b border-white/5">
      <div class="max-w-6xl mx-auto flex items-center justify-between gap-4">
        <a href={MAIN_SITE_URL} rel="noopener noreferrer" class="flex-shrink-0">
          <Image src={logo} alt="Wild Child Day Camps" class="h-16 w-auto object-contain" loading="eager" quality={70} />
        </a>

        <!-- Anchor nav (tablet+) -->
        <nav class="hidden md:flex items-center gap-6 text-white/75 text-sm font-medium">
          <a href="#about" class="hover:text-tangerine transition-colors">About</a>
          <a href="#programs" class="hover:text-tangerine transition-colors">What We Offer</a>
          <a href="#why-us" class="hover:text-tangerine transition-colors">Why Choose Us</a>
        </nav>

        <div class="flex items-center gap-4">
          <!-- Social links -->
          <div class="flex items-center gap-3">
            <a href="https://facebook.com/wildchildprograms" target="_blank" rel="noopener noreferrer" aria-label="Wild Child on Facebook" class="text-white/70 hover:text-tangerine transition-colors" data-umami-event="outbound-link-click" data-umami-event-url="https://facebook.com/wildchildprograms">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
            <a href="https://instagram.com/wildchildcolorado" target="_blank" rel="noopener noreferrer" aria-label="Wild Child on Instagram" class="text-white/70 hover:text-tangerine transition-colors" data-umami-event="outbound-link-click" data-umami-event-url="https://instagram.com/wildchildcolorado">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </a>
          </div>
          <!-- Divider -->
          <span class="w-px h-5 bg-white/15"></span>
          <!-- Phone -->
          <a href="tel:9703895611" class="hidden sm:flex items-center gap-1.5 text-white/80 hover:text-tangerine text-sm transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            970-389-5611
          </a>
          <!-- Register CTA -->
          <a
            href={FUNJOIN_URL}
            target="_blank"
            rel="noopener noreferrer"
            data-umami-event="Register Now - Header"
            data-umami-event-url={FUNJOIN_URL}
            class="bg-ember hover:bg-ember/90 text-white font-bold text-sm px-4 py-2 rounded-full transition-all hover:scale-105 active:scale-100 shadow-md"
          >
            Register Now
          </a>
        </div>
      </div>
    </header>

    <!-- ── 2. HERO: headline + form above the fold ── -->
    <section class="relative bg-boulder text-white overflow-hidden min-h-screen flex items-center">
      <Image
        src={kids}
        alt="Kids on a mountain summit in Colorado"
        class="absolute inset-0 w-full h-full object-cover opacity-20"
        loading="eager"
        fetchpriority="high"
        quality={60}
      />
      <div class="relative z-10 w-full max-w-6xl mx-auto px-6 py-16 lg:py-24">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

          <!-- Left: value proposition -->
          <div>
            <span class="inline-block bg-tangerine text-boulder text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full mb-6">
              Westminster, CO · Ages 6–15
            </span>
            <h1 class="font-display text-5xl sm:text-6xl md:text-7xl leading-none mb-3">
              Outdoor Summer Camp<br />for Kids Ages 6–15
            </h1>
            <p class="text-tangerine/90 text-sm font-semibold tracking-wide uppercase mb-6">
              Westminster, Colorado · Nature-Based Learning · Summer 2026 Registration Open
            </p>
            <p class="text-white/80 text-lg mb-8 leading-relaxed max-w-md">
              Colorado's #1 adventure day camp: hiking, rafting, rock climbing, marine science, and friendships that last all year. Most popular weeks already booked.
            </p>
            <ul class="space-y-3 mb-8">
              {[
                '1:6 counselor-to-camper ratio, with real attention every day',
                'Award-winning director with 26 years in youth development',
                'Licensed & insured, trusted by Front Range families since 1999',
              ].map((item) => (
                <li class="flex items-start gap-3 text-white/90 text-sm">
                  <svg class="w-5 h-5 text-tangerine mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
            <a
              href="#form"
              class="inline-flex items-center gap-2 text-tangerine hover:text-white text-sm font-semibold transition-colors underline underline-offset-4 md:hidden"
            >
              Reserve your spot below
            </a>
          </div>

          <!-- Right: CTA card -->
          <div id="form" class="bg-white rounded-2xl shadow-2xl p-8 text-carbon flex flex-col justify-between gap-8">
            <div>
              <p class="text-ember font-bold uppercase tracking-widest text-xs mb-3">Summer 2026 · Limited Spots</p>
              <h2 class="font-display text-4xl sm:text-5xl text-boulder leading-none mb-6">Ready to Register?</h2>
              <ul class="space-y-3 mb-8">
                {[
                  'Browse all programs: day camps, marine science, climbing & more',
                  'Pick your weeks and enroll directly in our registration system',
                  'Secure your child\'s spot before sessions sell out',
                ].map((item) => (
                  <li class="flex items-start gap-3 text-carbon/80 text-sm">
                    <svg class="w-5 h-5 text-ember mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <a
                href={FUNJOIN_URL}
                target="_blank"
                rel="noopener noreferrer"
                data-umami-event="Register Now - Hero"
                data-umami-event-url={FUNJOIN_URL}
                class="block w-full text-center bg-ember hover:bg-ember/90 text-white font-bold py-4 px-6 rounded-full text-lg transition-all shadow-lg hover:scale-[1.02] active:scale-100 mb-4"
              >
                Browse &amp; Register Now
              </a>
              <a
                href={MAIN_SITE_URL}
                rel="noopener noreferrer"
                data-umami-event="Learn More - Hero"
                class="block w-full text-center text-carbon/70 hover:text-carbon text-sm transition-colors underline underline-offset-2"
              >
                Learn more at wildchild.camp
              </a>
              <p class="text-center text-carbon/70 text-xs mt-4">Only a limited number of spots available, sessions filling quickly.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── 3. BENEFITS STRIP: scannable key features ── -->
    <section class="bg-ember py-12 px-6">
      <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {benefits.map((b) => (
          <div class="text-white">
            <div class="w-12 h-12 rounded-full bg-white/15 flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={b.icon} />
              </svg>
            </div>
            <p class="font-bold text-sm mb-0.5 text-white">{b.title}</p>
            <p class="text-white/90 text-xs">{b.sub}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ── 4. AUTHORITY QUOTE: social proof from an expert ── -->
    <section id="about" class="py-20 px-6 bg-white">
      <div class="max-w-4xl mx-auto text-center">
        <Image
          src={joel}
          alt="Joel Van Egbert, Wild Child Founder"
          class="w-24 h-24 rounded-full object-cover mx-auto mb-6 border-4 border-tangerine shadow-lg"
        />
        <blockquote class="font-display text-3xl sm:text-4xl md:text-5xl text-boulder leading-tight mb-6 max-w-3xl mx-auto">
          "Kids deserve to be treated like the people they hope to become."
        </blockquote>
        <p class="text-carbon/80 text-sm font-medium">
          Joel Van Egbert, Founder & Executive Director
        </p>
        <p class="text-ember font-bold text-sm mt-1">
          Early Childhood Educator of the Year · Camp Director of the Year
        </p>
      </div>
    </section>

    <!-- ── 5. PROGRAMS PREVIEW: what's included ── -->
    <section id="programs" class="py-16 px-6 bg-sandstone">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-10">
          <p class="text-ember font-semibold uppercase tracking-widest text-sm mb-2">What We Offer</p>
          <h2 class="font-display text-4xl sm:text-5xl text-boulder">Every Week Is an Adventure</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {programs.map((p) => (
            <a
              href={FUNJOIN_URL}
              target="_blank"
              rel="noopener noreferrer"
              data-umami-event={`Program - ${p.name}`}
              data-umami-event-url={FUNJOIN_URL}
              class="block bg-white rounded-xl p-5 border border-boulder/10 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all"
            >
              <div class="flex items-start justify-between mb-2">
                <h3 class="font-bold text-carbon text-sm leading-snug">{p.name}</h3>
                <span class="text-xs text-ember font-semibold bg-ember/10 px-2 py-0.5 rounded-full ml-2 flex-shrink-0">Ages {p.ages}</span>
              </div>
              <p class="text-carbon/80 text-xs leading-relaxed">{p.desc}</p>
            </a>
          ))}
        </div>
        <div class="text-center mt-8">
          <a
            href={FUNJOIN_URL}
            target="_blank"
            rel="noopener noreferrer"
            data-umami-event="Browse All Programs"
            data-umami-event-url={FUNJOIN_URL}
            class="inline-block text-boulder font-semibold text-sm hover:text-ember transition-colors underline underline-offset-4"
          >
            Browse all programs &amp; register
          </a>
          <p class="text-carbon/60 text-xs mt-3">Most popular weeks are already booked. Register now to secure your dates.</p>
        </div>
      </div>
    </section>

    <!-- ── 6. PHOTO CAROUSEL: infinite horizontal scroll ── -->
    <section
      class="bg-boulder py-10 overflow-hidden"
      style="mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);"
    >
      <div
        class="flex gap-3 w-max animate-[carousel-scroll_35s_linear_infinite]"
        aria-hidden="true"
      >
        {[...carouselPhotos, ...carouselPhotos].map((photo, i) => (
          <div class="w-52 h-52 flex-shrink-0 rounded-xl overflow-hidden">
            <Image
              src={photo}
              alt=""
              class="w-full h-full object-cover"
              width={208}
              height={208}
              quality={70}
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </section>

    <!-- ── 7. TESTIMONIALS: reviews & ratings from users ── -->
    <section class="py-20 px-6 bg-white">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <p class="text-ember font-semibold uppercase tracking-widest text-sm mb-2">What Parents Say</p>
          <h2 class="font-display text-4xl sm:text-5xl text-boulder mb-4">Colorado Families Love Wild Child</h2>
          <p class="text-carbon/80 max-w-lg mx-auto text-sm">
            Don't take our word for it. Hear from the parents and kids who come back year after year.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {testimonials.map((t) => (
            <div class="bg-sandstone rounded-2xl p-7 border border-boulder/10 flex flex-col">
              <div class="flex gap-0.5 mb-4">
                {[...Array(5)].map(() => (
                  <svg class="w-4 h-4 text-tangerine" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="text-carbon/80 text-sm leading-relaxed flex-1 mb-5">"{t.quote}"</p>
              <div>
                <p class="font-bold text-carbon text-sm">{t.name}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── 8. TRUST / GUARANTEES: security & reassurances ── -->
    <section id="why-us" class="bg-boulder py-16 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="font-display text-3xl sm:text-4xl text-white">Why Parents Trust Wild Child</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
          {trustItems.map((item) => (
            <div class="text-center">
              <div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center mx-auto mb-4">
                <svg class="w-6 h-6 text-tangerine" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
                </svg>
              </div>
              <h3 class="font-bold text-white text-sm mb-1">{item.title}</h3>
              <p class="text-white/60 text-xs leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── 9. SECOND CTA: urgency-driven, bottom of page ── -->
    <section class="bg-gradient-ember py-20 px-6 text-white text-center">
      <div class="max-w-2xl mx-auto">

        <!-- Mini testimonial strip -->
        <div class="flex flex-col sm:flex-row justify-center gap-6 mb-12">
          {[
            { quote: "Worth every penny.", name: "Marcus T." },
            { quote: "Nothing compares.", name: "Jennifer K." },
            { quote: "My daughters cannot wait to go back.", name: "Jaclyn U." },
          ].map((t) => (
            <div class="text-center">
              <p class="text-tangerine font-display text-2xl leading-none mb-1">"</p>
              <p class="text-white/90 text-sm italic">"{t.quote}"</p>
              <p class="text-white/60 text-xs mt-1">— {t.name}</p>
            </div>
          ))}
        </div>

        <p class="font-display text-lg tracking-widest uppercase text-white/80 mb-4">Summer 2026</p>
        <h2 class="font-display text-5xl sm:text-6xl md:text-7xl mb-6">Spots Are Going Fast</h2>
        <p class="text-white/80 text-lg mb-8 leading-relaxed">
          Only a limited number of spots remain for Summer 2026. Most popular weeks are already booked, don't wait until your child's session is gone.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={FUNJOIN_URL}
            target="_blank"
            rel="noopener noreferrer"
            data-umami-event="Register Now - Bottom"
            data-umami-event-url={FUNJOIN_URL}
            class="inline-block bg-white text-ember font-bold py-4 px-10 rounded-full text-lg hover:bg-sandstone transition-all shadow-xl hover:scale-105"
          >
            Register Now
          </a>
          <a
            href={MAIN_SITE_URL}
            rel="noopener noreferrer"
            data-umami-event="Learn More - Bottom"
            class="inline-block bg-white/10 hover:bg-white/20 border border-white/40 text-white font-semibold py-4 px-10 rounded-full text-lg transition-all backdrop-blur-sm"
          >
            Learn More at wildchild.camp
          </a>
        </div>
        <p class="mt-6 text-white/60 text-sm">
          Questions? Call us at{" "}
          <a href="tel:9703895611" class="underline hover:text-white transition-colors">970-389-5611</a>
        </p>
      </div>
    </section>

    <!-- ── MINIMAL FOOTER ── -->
    <footer class="bg-carbon text-white py-10 px-6">
      <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-4">
          <Image src={logo} alt="Wild Child Day Camps" class="h-10 w-auto object-contain" />
          <address class="not-italic text-white/50 text-xs leading-relaxed">
            Woodrow Wilson Academy<br />
            8300 W 94th Ave · Westminster, CO 80021
          </address>
        </div>
        <div class="text-center sm:text-right">
          <a href="tel:9703895611" class="text-tangerine hover:text-white font-semibold text-sm transition-colors block mb-1">
            970-389-5611
          </a>
          <p class="text-white/60 text-xs">
            © {new Date().getFullYear()} Wild Child Day Camps. All rights reserved.
          </p>
        </div>
      </div>
    </footer>

</Layout>
