---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import logo from "../assets/logo.webp";

const FUNJOIN_URL = "https://wildchildcamp.funjoin.app/explore-offerings";
const MAIN_SITE_URL = "https://wildchild.camp";

const benefits = [
	{
		icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
		title: "Weekly Outdoor Adventures",
		sub: "New Colorado destination every week",
	},
	{
		icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z",
		title: "1:6 Staff Ratio",
		sub: "Real attention for every camper",
	},
	{
		icon: "M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z",
		title: "Award-Winning Director",
		sub: "Director & Educator of the Year",
	},
	{
		icon: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
		title: "26 Years Running",
		sub: "Trusted by families since 1999",
	},
];

const testimonials = [
	{
		quote:
			"You are amazing at what you do and your passion and love for camps shows!!! My daughters cannot wait to be back in your camps!!!",
		name: "Jaclyn U.",
	},
	{
		quote:
			"Worth every penny. The 1:6 ratio is real — my son knows every counselor by name. He came home from whitewater rafting week telling me he wants to be a river guide. That's Wild Child.",
		name: "Marcus T.",
	},
	{
		quote:
			"We tried three camps before finding Wild Child. Nothing compares. The staff is exceptional, the programming is intentional, and my kids beg to go back every single year.",
		name: "Jennifer K.",
	},
];

const trustItems = [
	{
		title: "Award-Winning Director",
		desc: "Early Childhood Educator of the Year & Camp Director of the Year",
	},
	{
		title: "1:6 Staff Ratio",
		desc: "Personal attention for every camper — every single day",
	},
	{
		title: "Licensed & Insured",
		desc: "Professional, safe, and fully certified in Colorado",
	},
	{
		title: "26 Years Experience",
		desc: "Trusted by Front Range families since 1999",
	},
];
---

<Layout
  title="Wild Child Day Camps — Reserve Your Summer 2026 Spot"
  description="Colorado's #1 adventure day camp for kids ages 6–15. Hiking, rafting, climbing & more. Reserve your Summer 2026 spot today — spots fill fast."
>

    <!-- ── 1. MINIMAL HEADER — logo + phone only, no nav distractions ── -->
    <header class="bg-espresso px-6 py-4 sticky top-0 z-50 shadow-lg">
      <div class="max-w-6xl mx-auto flex items-center justify-between">
          <a href={MAIN_SITE_URL} target="_blank" rel="noopener noreferrer">
            <Image src={logo} alt="Wild Child Day Camps" class="h-20 w-auto object-contain" />
          </a>
        <div class="flex items-center gap-5">
          <!-- Social links -->
          <a href="https://facebook.com/wildchildprograms" target="_blank" rel="noopener noreferrer" aria-label="Wild Child on Facebook" class="text-white/50 hover:text-tangerine transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://instagram.com/wildchildcolorado" target="_blank" rel="noopener noreferrer" aria-label="Wild Child on Instagram" class="text-white/50 hover:text-tangerine transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <!-- Phone -->
          <a href="tel:9703895611" class="text-tangerine hover:text-white font-semibold text-sm transition-colors flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            970-389-5611
          </a>
        </div>
      </div>
    </header>

    <!-- ── 2. HERO — headline + form above the fold ── -->
    <section class="relative bg-espresso text-white overflow-hidden min-h-[85vh] flex items-center">
      <img
        src="https://img1.wsimg.com/isteam/ip/45bd3bbc-8957-4e8e-b462-e3f7bad11893/IMG_6350-e023c33.jpeg/:/rs=w:1200,m"
        alt="Kids on a mountain summit in Colorado"
        class="absolute inset-0 w-full h-full object-cover opacity-20"
        loading="eager"
      />
      <div class="relative z-10 w-full max-w-6xl mx-auto px-6 py-16 lg:py-24">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

          <!-- Left: value proposition -->
          <div>
            <span class="inline-block bg-amber text-carbon text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full mb-6">
              Westminster, CO · Ages 6–15
            </span>
            <h1 class="font-display text-5xl sm:text-6xl md:text-7xl leading-none mb-6">
              Your Kid's Best<br />Summer<br />Starts Here
            </h1>
            <p class="text-white/80 text-lg mb-8 leading-relaxed max-w-md">
              Colorado's #1 adventure day camp — hiking, rafting, rock climbing, marine science, and friendships that last all year.
            </p>
            <ul class="space-y-3 mb-8">
              {[
                '1:6 counselor-to-camper ratio — real attention, every day',
                'Award-winning director with 26 years in youth development',
                'Licensed & insured — trusted by Front Range families since 1999',
              ].map((item) => (
                <li class="flex items-start gap-3 text-white/90 text-sm">
                  <svg class="w-5 h-5 text-tangerine mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
            <a
              href="#form"
              class="inline-flex items-center gap-2 text-tangerine hover:text-white text-sm font-semibold transition-colors underline underline-offset-4 md:hidden"
            >
              Reserve your spot below ↓
            </a>
          </div>

          <!-- Right: CTA card -->
          <div class="bg-white rounded-2xl shadow-2xl p-8 text-carbon flex flex-col justify-between gap-8">
            <div>
              <p class="text-ember font-bold uppercase tracking-widest text-xs mb-3">Summer 2026 · Limited Spots</p>
              <h2 class="font-display text-4xl sm:text-5xl text-espresso leading-none mb-6">Ready to Register?</h2>
              <ul class="space-y-3 mb-8">
                {[
                  'Browse all programs — day camps, marine science, climbing & more',
                  'Pick your weeks and enroll directly in our registration system',
                  'Secure your child\'s spot before sessions sell out',
                ].map((item) => (
                  <li class="flex items-start gap-3 text-carbon/80 text-sm">
                    <svg class="w-5 h-5 text-ember mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <a
                href={FUNJOIN_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="block w-full text-center bg-ember hover:bg-ember-dark text-white font-bold py-4 px-6 rounded-full text-lg transition-all shadow-lg hover:scale-[1.02] active:scale-100 mb-4"
              >
                Browse &amp; Register Now
              </a>
              <a
                href={MAIN_SITE_URL}
                rel="noopener noreferrer"
                class="block w-full text-center text-carbon/50 hover:text-carbon text-sm transition-colors underline underline-offset-2"
              >
                Learn more at wildchild.camp
              </a>
              <p class="text-center text-carbon/40 text-xs mt-4">Every week sells out — spots go fast.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── 3. BENEFITS STRIP — scannable key features ── -->
    <section class="bg-aqua py-12 px-6">
      <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {benefits.map((b) => (
          <div class="text-white">
            <div class="w-12 h-12 rounded-full bg-white/15 flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={b.icon} />
              </svg>
            </div>
            <p class="font-bold text-sm mb-0.5 text-white">{b.title}</p>
            <p class="text-white/70 text-xs">{b.sub}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ── 4. AUTHORITY QUOTE — social proof from an expert ── -->
    <section class="py-20 px-6 bg-white">
      <div class="max-w-4xl mx-auto text-center">
        <img
          src="https://img1.wsimg.com/isteam/ip/45bd3bbc-8957-4e8e-b462-e3f7bad11893/1479497_10151814730728061_603931058_n.jpg/:/cr=t:0%25,l:0%25,w:100%25,h:100%25/rs=w:200,h:200,cg:true"
          alt="Joel Van Egbert, Wild Child Founder"
          class="w-24 h-24 rounded-full object-cover mx-auto mb-6 border-4 border-tangerine shadow-lg"
        />
        <blockquote class="font-display text-3xl sm:text-4xl md:text-5xl text-espresso leading-tight mb-6 max-w-3xl mx-auto">
          "Kids deserve to be treated like the people they hope to become."
        </blockquote>
        <p class="text-carbon/60 text-sm font-medium">
          Joel Van Egbert — Founder & Executive Director
        </p>
        <p class="text-ember font-bold text-sm mt-1">
          Early Childhood Educator of the Year · Camp Director of the Year
        </p>
      </div>
    </section>

    <!-- ── 5. PROGRAMS PREVIEW — what's included ── -->
    <section class="py-16 px-6 bg-[#FFF8F0]">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-10">
          <p class="text-ember font-semibold uppercase tracking-widest text-sm mb-2">What We Offer</p>
          <h2 class="font-display text-4xl sm:text-5xl text-espresso">Every Week Is an Adventure</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {[
            { name: "Summer Day Camps", ages: "6–16", desc: "Hiking, rafting, climbing & more — new destination every week" },
            { name: "SPLASH Marine Science", ages: "6–15", desc: "Underwater discovery with real biologists from Ocean First" },
            { name: "Enrichment Programs", ages: "6–15", desc: "HOWL & FAME — hands-on wilderness skills, art, music, science" },
            { name: "REACH Climbing Club", ages: "7–15", desc: "Weekly bouldering & top-rope sessions at GL Climbing" },
            { name: "SPARK Creative Writing", ages: "2nd grade+", desc: "Storytelling and poetry led by a CU Boulder MA student" },
            { name: "And More...", ages: "6–15", desc: "Browse all sessions and enroll directly " },
          ].map((p) => (
            <a
              href={FUNJOIN_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="block bg-white rounded-xl p-5 border border-espresso/10 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all"
            >
              <div class="flex items-start justify-between mb-2">
                <h3 class="font-bold text-carbon text-sm leading-snug">{p.name}</h3>
                <span class="text-xs text-ember font-semibold bg-ember/10 px-2 py-0.5 rounded-full ml-2 flex-shrink-0">Ages {p.ages}</span>
              </div>
              <p class="text-carbon/60 text-xs leading-relaxed">{p.desc}</p>
            </a>
          ))}
        </div>
        <div class="text-center mt-8">
          <a
            href={FUNJOIN_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block text-espresso font-semibold text-sm hover:text-ember transition-colors underline underline-offset-4"
          >
            Browse all programs &amp; register  
          </a>
        </div>
      </div>
    </section>

    <!-- ── 6. TESTIMONIALS — reviews & ratings from users ── -->
    <section class="py-20 px-6 bg-white">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <p class="text-ember font-semibold uppercase tracking-widest text-sm mb-2">What Parents Say</p>
          <h2 class="font-display text-4xl sm:text-5xl text-espresso mb-4">Colorado Families Love Wild Child</h2>
          <p class="text-carbon/60 max-w-lg mx-auto text-sm">
            Don't take our word for it — hear from the parents and kids who come back year after year.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {testimonials.map((t) => (
            <div class="bg-[#FFF8F0] rounded-2xl p-7 border border-espresso/10 flex flex-col">
              <div class="flex gap-0.5 mb-4">
                {[...Array(5)].map(() => (
                  <svg class="w-4 h-4 text-tangerine" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="text-carbon/80 text-sm leading-relaxed flex-1 mb-5">"{t.quote}"</p>
              <div>
                <p class="font-bold text-carbon text-sm">{t.name}</p>
                <p class="text-carbon/50 text-xs mt-0.5">{t.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── 7. TRUST / GUARANTEES — security & reassurances ── -->
    <section class="bg-espresso py-16 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="font-display text-3xl sm:text-4xl text-white">Why Parents Trust Wild Child</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
          {trustItems.map((item) => (
            <div class="text-center">
              <div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center mx-auto mb-4">
                <svg class="w-6 h-6 text-tangerine" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <h3 class="font-bold text-white text-sm mb-1">{item.title}</h3>
              <p class="text-white/60 text-xs leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── 8. SECOND CTA — urgency-driven, bottom of page ── -->
    <section class="bg-gradient-ember py-20 px-6 text-white text-center">
      <div class="max-w-2xl mx-auto">
        <p class="font-display text-lg tracking-widest uppercase text-white/80 mb-4">Summer 2026</p>
        <h2 class="font-display text-5xl sm:text-6xl md:text-7xl mb-6">Spots Are Going Fast</h2>
        <p class="text-white/80 text-lg mb-8 leading-relaxed">
          Every week sells out. Don't wait until your child's preferred session is gone — secure their spot today.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={FUNJOIN_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block bg-white text-ember font-bold py-4 px-10 rounded-full text-lg hover:bg-[#FFF8F0] transition-all shadow-xl hover:scale-105"
          >
            Register Now 
          </a>
          <a
            href={MAIN_SITE_URL}
            rel="noopener noreferrer"
            class="inline-block bg-white/10 hover:bg-white/20 border border-white/40 text-white font-semibold py-4 px-10 rounded-full text-lg transition-all backdrop-blur-sm"
          >
            Learn More at wildchild.camp
          </a>
        </div>
        <p class="mt-6 text-white/60 text-sm">
          Questions? Call us at{" "}
          <a href="tel:9703895611" class="underline hover:text-white transition-colors">970-389-5611</a>
        </p>
      </div>
    </section>

    <!-- ── MINIMAL FOOTER ── -->
    <footer class="bg-carbon text-white py-10 px-6">
      <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-4">
          <Image src={logo} alt="Wild Child Day Camps" class="h-10 w-auto object-contain" />
          <address class="not-italic text-white/50 text-xs leading-relaxed">
            Woodrow Wilson Academy<br />
            8300 W 94th Ave · Westminster, CO 80021
          </address>
        </div>
        <div class="text-center sm:text-right">
          <a href="tel:9703895611" class="text-tangerine hover:text-white font-semibold text-sm transition-colors block mb-1">
            970-389-5611
          </a>
          <p class="text-white/40 text-xs">
            © {new Date().getFullYear()} Wild Child Day Camps. All rights reserved.
          </p>
        </div>
      </div>
    </footer>

</Layout>
