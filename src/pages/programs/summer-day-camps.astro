---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import CTABanner from '../../components/CTABanner.astro';
import Hero from '../../components/Hero.astro';
import WeeklyFormula from '../../components/WeeklyFormula.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Summer Day Camps | Wild Child Colorado"
  description="Wild Child Summer Day Camps — weekly themed adventures for kids ages 6–16 on Colorado's Front Range. Hiking, swimming, field trips, and more."
>
  <CTABanner />
  <Navbar />

  <main>
    <Hero
      headline="Summer Day Camps"
      subheadline="Themed Adventures · Ages 6–16 · Westminster, CO"
      compact={true}
      imageSrc="https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?w=1600&q=80"
      imageAlt="Kids hiking in the Colorado mountains"
    />

    <section class="py-20 px-6 bg-cream">
      <div class="max-w-4xl mx-auto">
        <div class="prose max-w-none">
          <p class="text-sunset font-semibold uppercase tracking-widest text-sm mb-2">The Experience</p>
          <h2 class="font-display text-5xl text-forest mb-6">Colorado's Premier Trip & Travel Camp</h2>
          <p class="text-charcoal/70 text-lg leading-relaxed mb-6">
            Wild Child Summer Day Camps blend youth development with the best Colorado has to offer.
            Every week brings a new theme and a new set of adventures — from mountain summits to
            whitewater rapids to the front-row seat at a museum or zoo.
          </p>
          <p class="text-charcoal/70 text-lg leading-relaxed mb-6">
            With a 1:6 counselor-to-camper ratio, every child gets the attention they deserve.
            Our award-winning program director and passionate team create an environment where
            campers can grow, connect, and be exactly who they want to be.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 my-10">
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-forest/10 text-center">
              <div class="text-4xl mb-3">👨‍👧</div>
              <div class="font-display text-3xl text-forest">1:6</div>
              <div class="text-charcoal/60 text-sm mt-1">Counselor-to-camper ratio</div>
            </div>
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-forest/10 text-center">
              <div class="text-4xl mb-3">🎒</div>
              <div class="font-display text-3xl text-forest">6–16</div>
              <div class="text-charcoal/60 text-sm mt-1">Ages welcome</div>
            </div>
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-forest/10 text-center">
              <div class="text-4xl mb-3">🏔</div>
              <div class="font-display text-3xl text-forest">5 Days</div>
              <div class="text-charcoal/60 text-sm mt-1">Per themed week</div>
            </div>
          </div>

          <h3 class="font-display text-3xl text-forest mb-4">Base Location</h3>
          <p class="text-charcoal/70 leading-relaxed mb-2">
            Woodrow Wilson Academy<br />
            8300 W 94th Ave, Westminster, CO 80021
          </p>
          <p class="text-charcoal/60 text-sm">
            Camp runs from this location each day with buses departing for adventures across the Front Range.
          </p>
        </div>
      </div>
    </section>

    <WeeklyFormula />

    <!-- CTA -->
    <section class="bg-forest py-16 px-6 text-center text-white">
      <h2 class="font-display text-5xl mb-4">Ready for the Best Summer Yet?</h2>
      <p class="text-white/70 mb-8 text-lg">2026 registration is open and spots are going fast.</p>
      <a
        href="https://wildchildcamp.funjoin.app"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-sunset hover:bg-sunset-dark text-white font-bold py-4 px-10 rounded-full text-lg transition-all"
      >
        Register Now
      </a>
    </section>
  </main>

  <Footer />
</Layout>
