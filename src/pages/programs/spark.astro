---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import CTABanner from '../../components/CTABanner.astro';
import Hero from '../../components/Hero.astro';
import Footer from '../../components/Footer.astro';

const schedule = [
  { date: 'April 21', topic: 'Story Generation & World-Building' },
  { date: 'April 28', topic: 'Poetry & Finding Your Voice' },
  { date: 'May 5', topic: 'Journaling & Personal Narrative' },
  { date: 'May 12', topic: 'Writing Craft Techniques' },
  { date: 'May 19', topic: 'Collaborative Projects & Showcase' },
];
---

<Layout
  title="SPARK Creative Writing | Wild Child Colorado"
  description="SPARK Creative Writing — storytelling, poetry, journaling, and collaborative projects for students 2nd grade and up. Led by Aria (CU Boulder MA)."
>
  <CTABanner />
  <Navbar />

  <main>
    <Hero
      headline="SPARK Creative Writing"
      subheadline="Spark Your Imagination · Build Your Voice · Share Your Story"
      compact={true}
      imageSrc="https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=1600&q=80"
      imageAlt="Kids writing and creating stories"
      showCTA={false}
    />

    <section class="py-20 px-6 bg-cream">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
          <div>
            <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-2">About SPARK</p>
            <h2 class="font-display text-5xl text-charcoal mb-6">Every Kid Has a Story to Tell</h2>
            <p class="text-charcoal/70 leading-relaxed mb-4">
              SPARK your young person's imagination and love for writing. Through storytelling, poetry,
              journaling, and collaborative projects, students build confidence and find their unique voice.
            </p>
            <p class="text-charcoal/70 leading-relaxed mb-6">
              Led by Aria (Bonfire) — a Creative Writing degree holder and CU Boulder Master's student
              in Education — SPARK is designed for students in 2nd grade and up at Woodrow Wilson Academy.
            </p>

            <div class="space-y-2 mb-8">
              {[
                'Story generation & world-building',
                'Poetry & personal voice',
                'Journaling techniques',
                'Writing craft skills',
                'Collaborative group projects',
                'End-of-season writing showcase',
              ].map((item) => (
                <div class="flex items-center gap-2 text-charcoal/70 text-sm">
                  <span class="w-1 h-1 rounded-full bg-gold flex-shrink-0" />
                  {item}
                </div>
              ))}
            </div>

            <div class="bg-gold/10 border border-gold/30 rounded-2xl p-5">
              <p class="font-bold text-charcoal text-sm mb-2">What to Bring</p>
              <p class="text-charcoal/60 text-sm">
                Durable journal/notebook, pencils, eraser, snack, water bottle.
                Wild Child supplies all other materials.
              </p>
            </div>
          </div>

          <div>
            <div class="bg-white rounded-2xl shadow-md p-6 mb-6">
              <p class="text-xs font-bold uppercase tracking-wider text-charcoal/40 mb-4">Spring 2026 Schedule</p>
              <div class="space-y-3">
                {schedule.map((s, i) => (
                  <div class="flex items-center gap-4">
                    <div class="w-8 h-8 rounded-full bg-gold flex items-center justify-center text-charcoal font-bold text-xs flex-shrink-0">
                      {i + 1}
                    </div>
                    <div>
                      <div class="text-xs text-charcoal/40 font-medium">{s.date}</div>
                      <div class="text-sm font-medium text-charcoal">{s.topic}</div>
                    </div>
                  </div>
                ))}
              </div>
              <div class="mt-4 pt-4 border-t border-charcoal/10 text-xs text-charcoal/50">
                Every Tuesday · Pickup at 4:30 PM at WWA
              </div>
            </div>

            <div class="space-y-4 mb-6">
              <div class="bg-white rounded-2xl shadow-md border border-charcoal/10 p-5">
                <div class="text-2xl font-display text-charcoal mb-1">$30</div>
                <div class="text-charcoal font-semibold text-sm">Per Session</div>
                <p class="text-charcoal/50 text-xs mt-1">Minimum 4 sessions required.</p>
              </div>
              <div class="bg-charcoal rounded-2xl shadow-md p-5 text-white relative overflow-hidden">
                <div class="absolute top-3 right-3 bg-gold text-charcoal text-xs font-bold px-2 py-0.5 rounded-full">
                  Best Value
                </div>
                <div class="text-2xl font-display mb-1">$150</div>
                <div class="font-semibold text-sm">Full Season (5 sessions)</div>
                <p class="text-white/60 text-xs mt-1">Never miss a session.</p>
              </div>
            </div>

            <a
              href="https://wildchildcamp.funjoin.app"
              target="_blank"
              rel="noopener noreferrer"
              class="block w-full text-center bg-gold hover:bg-gold/80 text-charcoal font-bold py-4 px-8 rounded-full text-lg transition-colors"
            >
              Register for SPARK
            </a>
            <p class="text-center text-charcoal/50 text-xs mt-3">
              Questions? Call 970-389-5611
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
