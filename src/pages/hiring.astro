---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import CTABanner from '../components/CTABanner.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';

const perks = [
  { label: 'Outdoor Adventures', desc: 'Lead kids on real Colorado adventures — rafting, climbing, hiking, and more.' },
  { label: 'Real Impact', desc: "You'll help shape the kind of people these kids grow up to be." },
  { label: 'Award-Winning Program', desc: "Join a team led by Colorado's Camp Director of the Year." },
  { label: 'Tight-Knit Team', desc: 'A small crew that genuinely cares about each other and the work.' },
];
---

<Layout
  title="Now Hiring | Wild Child Colorado"
  description="Join the Wild Child Day Camps team. We're looking for passionate educators and outdoor specialists who love working with kids."
>
  <CTABanner />
  <Navbar />

  <main>
    <Hero
      headline="Join the Wild Child Team"
      subheadline="We're Hiring Passionate Educators & Adventure Specialists"
      compact={true}
      imageSrc="https://images.unsplash.com/photo-1526976668912-1a811878dd37?w=1600&q=80"
      imageAlt="Camp counselors leading kids on an adventure"
      showCTA={false}
    />

    <section class="py-20 px-6 bg-cream">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <p class="text-sunset font-semibold uppercase tracking-widest text-sm mb-2">Now Hiring</p>
          <h2 class="font-display text-3xl sm:text-5xl text-forest mb-4">Do Work That Matters</h2>
          <p class="text-charcoal/60 max-w-xl mx-auto text-lg">
            Wild Child is looking for educators, outdoor specialists, and youth development
            professionals who believe kids deserve to be treated like the people they hope to become.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-12">
          {perks.map((p) => (
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-forest/10">
              <div class="w-8 h-1 bg-forest rounded-full mb-4" />
              <h3 class="font-bold text-charcoal mb-2">{p.label}</h3>
              <p class="text-charcoal/60 text-sm leading-relaxed">{p.desc}</p>
            </div>
          ))}
        </div>

        <div class="bg-forest text-white rounded-2xl p-8 text-center shadow-xl">
          <h3 class="font-display text-4xl mb-3">Ready to Apply?</h3>
          <p class="text-white/70 mb-6 max-w-md mx-auto">
            Get in touch — tell us about yourself and why Wild Child sounds like your kind of place.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href="tel:9703895611"
              class="bg-white text-forest font-bold py-3 px-8 rounded-full hover:bg-cream transition-colors"
            >
              Call 970-389-5611
            </a>
            <a
              href="https://instagram.com/wildchildcolorado"
              target="_blank"
              rel="noopener noreferrer"
              class="border border-white/40 text-white font-semibold py-3 px-8 rounded-full hover:bg-white/10 transition-colors"
            >
              DM @wildchildcolorado
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
